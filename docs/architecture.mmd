graph TD
    subgraph Input
        Q["User Query"]
    end

    subgraph Stage1["Stage 1: Context Retrieval"]
        MEM["Persistent Memory Store<br/>(SQLite + FTS5)"]
        FTS["Full-Text Search"]
        TOP["Topic Index Lookup"]
    end

    subgraph Stage2["Stage 2: Context Processing"]
        CB["Context Builder<br/>(Filter + Rank + Compress)"]
        CSE["CSE: Context Sufficiency<br/>Estimation"]
        MCD["MCD: Memory Conflict<br/>Detection"]
        CDPS["CDPS: Confidence-Driven<br/>Prompt Shaping"]
        SECR["SECR: Self-Evolving<br/>Compression Rules"]
    end

    subgraph Stage3["Stage 3: Routing & Inference"]
        CDDR["CDDR: Confidence-Driven<br/>Dynamic Router"]
        T1["Tier 1: Local SLM<br/>(Ollama, $0)"]
        T2["Tier 2: Claude Sonnet<br/>(API, $$)"]
        T3["Tier 3: Claude Opus<br/>(API, $$$)"]
    end

    subgraph Output
        R["Response"]
    end

    Q --> FTS
    Q --> TOP
    FTS --> MEM
    TOP --> MEM
    MEM --> CB
    CB --> CSE
    CSE --> MCD
    MCD --> CDPS
    CDPS --> SECR
    SECR --> CDDR

    CDDR -->|"High Confidence<br/>+ Sufficient"| T1
    CDDR -->|"Moderate Confidence<br/>OR Conflicts"| T2
    CDDR -->|"Low Confidence<br/>OR Critical Conflicts"| T3

    T1 -->|"Cascade on failure"| T2
    T2 -->|"Cascade on failure"| T3

    T1 --> R
    T2 --> R
    T3 --> R

    R -.->|"Background Learning:<br/>Update usage stats,<br/>evolve SECR rules"| MEM

